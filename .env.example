# Navi environment mode
# development | production
NAVI_ENV=development

# Provider defaults (override config.toml defaults for local development)
# Allowed: nvidia | openai | groq | openrouter | ollama
NAVI_DEFAULT_PROVIDER=openai
NAVI_DEFAULT_MODEL=gpt-4o-mini

# API key source
# Option A (recommended for .env in development): direct key
NAVI_API_KEY=your_provider_api_key_here

# Option B: key comes from a named env var
# NAVI_DEFAULT_API_KEY_ENV=OPENAI_API_KEY
# OPENAI_API_KEY=your_provider_api_key_here

# Optional: override LLM endpoint (local proxy/httptest)
# NAVI_LLM_BASE_URL=http://localhost:8081/v1
